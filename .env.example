# QWEN_API_KEY: Alibaba Qwen API Key
QWEN_API_KEY="MY_QWEN_API_KEY"

# NVIDIA_API_KEY: NVIDIA API Key
NVIDIA_API_KEY="MY_NVIDIA_API_KEY"

# KILO_API_KEY: Kilo Code API Key
KILO_API_KEY="MY_KILO_API_KEY"